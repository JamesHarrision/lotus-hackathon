// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 1. Định nghĩa 3 Role chuẩn chỉ
enum Role {
  SUPERADMIN // Quản trị viên hệ thống của bọn ông
  ENTERPRISE // Doanh nghiệp (VD: Highlands Coffee, Phê La)
  USER // Khách hàng đầu cuối
}

// Trạng thái của lệnh điều hướng
enum RoutingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

// 2. Bảng User dùng chung cho cả 3 Role
model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  role     Role    @default(USER)
  name     String?
  phone    String?

  // Quan hệ
  enterprise Enterprise? // Chỉ có data nếu role là ENTERPRISE
  routings   RoutingHistory[] // Lịch sử điều hướng của khách hàng

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. Bảng Enterprise (Doanh nghiệp)
model Enterprise {
  id     Int    @id @default(autoincrement())
  name   String // Tên chuỗi, ví dụ: "Highlands Coffee"
  userId Int    @unique // Nối với tài khoản có role ENTERPRISE
  user   User   @relation(fields: [userId], references: [id])

  branches   Branch[]
  incentives Incentive[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 4. Bảng Branch (Chi nhánh) - Nguồn data sống cho Min-Cost Max-Flow
model Branch {
  id          Int     @id @default(autoincrement())
  name        String
  address     String?
  lat         Float // Tọa độ để tính khoảng cách (Edge cost)
  lng         Float
  maxCapacity Int     @default(50) // Sức chứa tối đa (Max Flow qua node)
  currentLoad Int     @default(0) // Lượng khách do AI đếm real-time cập nhật vào đây

  cameraUrl String?

  enterpriseId Int
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id])

  // Quan hệ cho phần log điều hướng
  routingsFrom RoutingHistory[] @relation("FromBranch")
  routingsTo   RoutingHistory[] @relation("ToBranch")

  // Quan hệ cho phần log tải (analytics)
  loadLogs BranchLoadLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 5. Bảng RoutingHistory (Lịch sử phân luồng)
model RoutingHistory {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  fromBranchId Int
  fromBranch   Branch @relation("FromBranch", fields: [fromBranchId], references: [id])

  toBranchId Int
  toBranch   Branch @relation("ToBranch", fields: [toBranchId], references: [id])

  status RoutingStatus @default(PENDING)

  // Thông số để show cho ban giám khảo thấy hệ thống hoạt động thông minh thế nào
  incentiveGiven String? // VD: "VOUCHER_20_PERCENT"
  calculatedCost Float? // Lưu lại cost mà thuật toán Min-Cost Max-Flow tính ra để tracking/debug
  estimatedWaitTime Float? // Thời gian chờ ước tính (phút) trả về từ AI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Bảng BranchLoadLog (Lịch sử tải của chi nhánh - phục vụ Analytics)
model BranchLoadLog {
  id          Int    @id @default(autoincrement())
  branchId    Int
  branch      Branch @relation(fields: [branchId], references: [id])
  currentLoad Int
  timestamp   DateTime @default(now())

  @@index([branchId, timestamp])
}

// 7. Bảng Incentive (Kho lưu trữ Voucher của doanh nghiệp)
model Incentive {
  id           Int        @id @default(autoincrement())
  enterpriseId Int
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id])
  
  code         String     @unique // VD: "HIGH50", "PHELA20"
  description  String?    // VD: "Giảm 50% khi chuyển vùng sang chi nhánh vắng hơn"
  discountVal  Float      // Giá trị giảm (VD: 50.0)
  isPercentage Boolean    @default(true) // Giảm theo % hay tiền mặt

  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
